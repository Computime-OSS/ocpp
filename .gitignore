# =============================================================================
# Credentials & Secrets (NEVER commit these)
# =============================================================================

# Environment files with secrets
.env
.env.*
!.env.example

# SSL/TLS certificates and keys
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
ca.srl

# Nginx credentials
nginx/auth/ocpp_passwd
nginx/certs/*.key
nginx/certs/*.crt
nginx/certs/*.pem
nginx/mtls/*.key
nginx/mtls/*.crt
nginx/mtls/*.csr
nginx/mtls/ca.srl
nginx/ca-state/*.srl

# Keep directory structure with .gitkeep
!**/.gitkeep

.ha-venv/

# =============================================================================
# Home Assistant - Excluded Files
# =============================================================================

# Root-level HA config (e.g. dev/symlink setup) - never commit local state or secrets
config/

# HA secrets (NEVER commit) - when using homeassistant/config/ path
homeassistant/config/secrets.yaml

# HA internal storage (user-specific, auto-generated)
homeassistant/config/.storage/

# HA database (large, user-specific)
homeassistant/config/home-assistant_v2.db
homeassistant/config/home-assistant_v2.db-shm
homeassistant/config/home-assistant_v2.db-wal

# HA version file (auto-generated)
homeassistant/config/.HA_VERSION

# HA run lock file
homeassistant/config/.ha_run.lock

# TTS cache (auto-generated)
homeassistant/config/tts/

# Python dependencies (auto-installed)
homeassistant/config/deps/

# Log files
homeassistant/config/*.log
homeassistant/config/*.log.*

# Blueprints (user-specific, can be downloaded)
homeassistant/config/blueprints/

# Custom components - users should install manually to get latest versions
homeassistant/config/custom_components/

# Frontend resources - users should install manually via HACS
homeassistant/config/www/

# =============================================================================
# Home Assistant - INCLUDED Essential Files (tracked in repo)
# =============================================================================
# These configuration files ARE tracked:
#   - homeassistant/config/configuration.yaml    (main config with OCPP templates)
#   - homeassistant/config/automations.yaml      (automation rules)
#   - homeassistant/config/scripts.yaml          (script definitions)
#   - homeassistant/config/scenes.yaml           (scene definitions)
#   - homeassistant/config/ocpp_dashboard_template.yaml (dashboard template)
#   - homeassistant/config/themes/               (theme directory structure)
#
# Users must manually install:
#   - OCPP Integration: https://github.com/lbbrhzn/ocpp (via HACS)
#   - Time Picker Card: https://github.com/GeorgeSG/lovelace-time-picker-card (via HACS)

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or not
#   install all needed dependencies.
#Pipfile.lock

# PEP 582; used by e.g. github.com/David-OConnor/pyflow
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# HA Development
/config/
.DS_Store
